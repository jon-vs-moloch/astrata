name = "astrata-mcp-relay"
main = "worker.js"
compatibility_date = "2026-04-10"

[vars]
ENVIRONMENT = "development"
RELAY_DEFAULT_PROFILE_ID = ""

# Set this with `wrangler secret put RELAY_SHARED_TOKEN`
# RELAY_SHARED_TOKEN = ""

# Optional but recommended for durable hosted queue state:
# [[kv_namespaces]]
# binding = "RELAY_STATE"
# id = "your_kv_namespace_id"
